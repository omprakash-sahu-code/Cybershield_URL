# CyberShield URL Scanner - Environment Variables Template
# Copy this file to '.env' and fill in your actual values.

# Google Safe Browsing API Key (Required for URL checking)
# Obtain from Google Cloud Console: https://console.cloud.google.com/
API_KEY=your_google_safe_browsing_api_key_here

# Gemini API Key (Required for scam chat analysis & image URL OCR extraction)
# Obtain from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Server Port (Defaults to 3002)
PORT=3002

# Optional: Custom CORS origins (Comma-separated list)
# CORS_ORIGINS=https://cybershield-url.netlify.app,http://localhost:3000

# Optional: Fetch timeout in milliseconds (Defaults to 5000)
# REQUEST_TIMEOUT_MS=5000

# Optional: Fetch retries for temporary failures (Defaults to 2)
# REQUEST_RETRIES=2
